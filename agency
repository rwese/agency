#!/usr/bin/env bash
# shellcheck disable=SC1090,SC2086,SC2164,SC2317

set -euo pipefail

# -------------------------------------------------------------------
# Agency - AI Agent Session Manager
#
# A simple tmux-based session manager for AI agents.
# Each agent runs in an isolated tmux session with persistent memory.
# -------------------------------------------------------------------

# Constants
readonly AGENCY_VERSION="0.1.0"
readonly AGENCY_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/agency"
readonly AGENTS_DIR="$AGENCY_DIR/agents"
readonly SESSION_PREFIX="agency-"

# Wordlist for session names (high-entropy, 1-token words)
# Curated list of common words that tokenize to 1 token
readonly -a WORDS=(
  swift bold dark warm cool gray neon iron soft loud
  wolf fox bear hawk owl crow fish deer lynx crane
  frog toad hare mole seal goat jade kite link node
  orb pipe raft slug tank void wire atom base byte
  cache daemon ether fiber graph hash json kernel
  lambda module object parse query root socket thread
  unix vector worker proxy relay stream token
)
readonly WORD_COUNT=59

# Graceful shutdown message sent to agents
readonly SHUTDOWN_MESSAGE="Please wrap up, save your memories to your memory file, then exit gracefully. Say 'Goodbye' when done."

# Graceful stop timeout (seconds)
readonly STOP_TIMEOUT=30

# Agent command (can be overridden via AGENCY_AGENT_CMD env var for testing)
get_agent_cmd() {
  printf '%s' "${AGENCY_AGENT_CMD:-pi}"
}

# -------------------------------------------------------------------
# Usage
# -------------------------------------------------------------------

usage() {
  cat <<EOF
Agency - AI Agent Session Manager v$AGENCY_VERSION

USAGE:
  agency <command> [arguments]

COMMANDS:
  init                   Create config skeleton in $AGENCY_DIR
  start <name> [--dir <path>]
                          Start an agent named <name>
                          Optionally specify working directory
  send <session> <msg>   Send a message to <session>
  list                   List all running agency sessions
  stop <session>         Gracefully stop <session> (waits up to 30s)
  kill <session>         Force kill <session>
  kill-all               Kill all agency sessions
  help                   Show this help message
  version                Show version

EXAMPLES:
  agency init
  agency start coder --dir ~/projects/myapp
  agency send coder dark-wolf "Fix the authentication bug"
  agency list
  agency stop coder dark-wolf
  agency kill-all

EOF
}

# -------------------------------------------------------------------
# Helpers
# -------------------------------------------------------------------

log_info() {
  printf '[INFO] %s\n' "$*" >&2
}

log_error() {
  printf '[ERROR] %s\n' "$*" >&2
}

# Get random word from wordlist
_get_random_word() {
  local n="${#WORDS[@]}"
  local r=$((RANDOM % n))
  printf '%s' "${WORDS[$r]}"
}

# Generate session name: {prefix}{agent-name}-{word1}-{word2}
# Uses high-entropy word pairs from curated wordlist
make_session_name() {
  local -r name="$1"
  local word1 word2
  word1="$(_get_random_word)"
  word2="$(_get_random_word)"
  printf '%s%s-%s-%s' "$SESSION_PREFIX" "$name" "$word1" "$word2"
}

# Check if a tmux session exists
session_exists() {
  local -r sess="$1"
  tmux has-session -t "$sess" 2>/dev/null
}

# Get working directory from config or default
get_agent_dir() {
  local -r cfg="$1"
  local -r override="${2:-}"

  if [[ -n "$override" ]]; then
    printf '%s' "$override"
  elif [[ -f "$cfg" ]] && command -v yq >/dev/null 2>&1; then
    yq -r '.working_dir // .dir // empty' "$cfg" 2>/dev/null || printf '%s' "$HOME"
  else
    printf '%s' "$HOME"
  fi
}

# Load agent config and extract field
load_config() {
  local -r agent="$1"
  local -r field="$2"
  local -r cfg="$AGENTS_DIR/${agent}.yaml"

  if [[ ! -f "$cfg" ]]; then
    log_error "Config not found: $cfg"
    return 1
  fi

  if command -v yq >/dev/null 2>&1; then
    yq -r ".$field" "$cfg" 2>/dev/null || true
  else
    # Fallback: simple grep-based extraction
    grep "^${field}:" "$cfg" 2>/dev/null | cut -d':' -f2- | sed 's/^ *//'
  fi
}

# Wait for session to exit with timeout
wait_for_exit() {
  local -r sess="$1"
  local -r timeout="$2"
  local -r interval=2
  local elapsed=0

  while ((elapsed < timeout)); do
    if ! session_exists "$sess"; then
      return 0
    fi
    sleep "$interval"
    elapsed=$((elapsed + interval))
  done

  return 1
}

# -------------------------------------------------------------------
# Commands
# -------------------------------------------------------------------

cmd_init() {
  log_info "Initializing agency config in $AGENCY_DIR"

  mkdir -p "$AGENTS_DIR"

  local -r example_cfg="$AGENTS_DIR/example.yaml"
  cat > "$example_cfg" <<'EOF'
name: example
memory_file: ~/.agency/memory/example.md
source_dir: ~/.agency/agents/example
storage_dir: ~/.agency/storage/example
working_dir: ~
EOF

  mkdir -p \
    "$HOME/.agency/memory/example" \
    "$HOME/.agency/storage/example"

  log_info "Created example config: $example_cfg"
  log_info "Edit the config and run: agency start example"
}

cmd_start() {
  local agent_name=""
  local override_dir="$HOME"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dir)
        override_dir="$2"
        shift 2
        ;;
      *)
        agent_name="$1"
        shift
        ;;
    esac
  done

  if [[ -z "$agent_name" ]]; then
    log_error "Agent name required"
    log_error "Usage: agency start <name> [--dir <path>]"
    return 1
  fi

  local -r cfg="$AGENTS_DIR/${agent_name}.yaml"

  if [[ ! -f "$cfg" ]]; then
    log_error "Config not found: $cfg"
    log_error "Run 'agency init' first or create $cfg"
    return 1
  fi

  # Load config fields
  local personality work_dir
  personality="$(load_config "$agent_name" "personality")" || true
  work_dir="$(get_agent_dir "$cfg" "$override_dir")"

  # Expand tildes
  work_dir="${work_dir/#\~/$HOME}"

  # Ensure working directory exists
  mkdir -p "$work_dir"

  # Generate session name
  local sess_name
  sess_name="$(make_session_name "$agent_name")"

  # Build the agent command
  local agent_bin
  agent_bin="$(get_agent_cmd)"
  
  # Build pi command with session dir and optional personality
  # Use a temp script to avoid shell escaping issues with personality text
  local -r agent_script="$AGENCY_DIR/sessions/${sess_name}.sh"
  mkdir -p "$(dirname "$agent_script")"
  
  {
    echo '#!/bin/bash'
    if [[ -n "$personality" ]]; then
      # Escape double quotes for safe embedding
      local escaped="${personality//\"/\\\"}"
      echo "exec $agent_bin --session-dir '$AGENCY_DIR/sessions' --append-system-prompt \\\"$escaped\\\"" 
    else
      echo "exec $agent_bin --session-dir '$AGENCY_DIR/sessions'"
    fi
  } > "$agent_script"
  chmod +x "$agent_script"

  # Create session and run agent with graceful stop handler
  tmux new-session -d -s "$sess_name" -c "$work_dir" \
    "trap 'echo \"$SHUTDOWN_MESSAGE\"' SIGTERM SIGINT; $agent_script"

  log_info "Started session: $sess_name"
  printf '%s' "$sess_name"
}

cmd_send() {
  local sess="$1"
  local msg="$2"

  if [[ -z "$sess" ]] || [[ -z "$msg" ]]; then
    log_error "Session and message required"
    log_error "Usage: agency send <session> <message>"
    return 1
  fi

  if ! session_exists "$sess"; then
    log_error "Session not found: $sess"
    return 1
  fi

  # Send message - use send-keys with quoted string
  tmux send-keys -t "$sess" "$msg" Enter
  log_info "Sent message to $sess"
}

cmd_list() {
  local sess agent status
  while IFS= read -r sess; do
    # Extract agent name from session (agency-name-word1-word2 -> name)
    agent="${sess#$SESSION_PREFIX}"
    # Agent name is everything before first -word (first two dashes)
    agent="${agent%%-*}"

    if session_exists "$sess"; then
      status="running"
    else
      status="exited"
    fi

    printf '%-30s %-15s %s\n' "$sess" "$agent" "$status"
  done < <(tmux list-sessions -F "#S" 2>/dev/null | grep "^$SESSION_PREFIX" || true)
}

cmd_stop() {
  local -r sess="$1"

  if [[ -z "$sess" ]]; then
    log_error "Session required"
    log_error "Usage: agency stop <session>"
    return 1
  fi

  if ! session_exists "$sess"; then
    log_error "Session not found: $sess"
    return 1
  fi

  log_info "Sending graceful shutdown signal to $sess..."

  # Send shutdown message
  tmux send-keys -t "$sess" "$SHUTDOWN_MESSAGE" Enter

  # Wait for exit
  if wait_for_exit "$sess" "$STOP_TIMEOUT"; then
    log_info "Session $sess stopped gracefully"
  else
    log_error "Session $sess did not stop within ${STOP_TIMEOUT}s"
    log_error "Use 'agency kill $sess' to force kill"
    return 1
  fi
}

cmd_kill() {
  local -r sess="$1"

  if [[ -z "$sess" ]]; then
    log_error "Session required"
    log_error "Usage: agency kill <session>"
    return 1
  fi

  if ! session_exists "$sess"; then
    log_error "Session not found: $sess"
    return 1
  fi

  log_info "Force killing $sess..."
  tmux kill-session -t "$sess"
  log_info "Session $sess killed"
}

cmd_kill_all() {
  local sessions
  sessions="$(tmux list-sessions -F "#S" 2>/dev/null | grep "^$SESSION_PREFIX" || true)"

  if [[ -z "$sessions" ]]; then
    log_info "No agency sessions running"
    return 0
  fi

  local count=0
  local s
  while IFS= read -r s; do
    tmux kill-session -t "$s" 2>/dev/null || true
    count=$((count + 1))
  done <<< "$sessions"

  log_info "Killed $count session(s)"
}

cmd_version() {
  printf 'agency version %s\n' "$AGENCY_VERSION"
}

# -------------------------------------------------------------------
# Main
# -------------------------------------------------------------------

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 1
  fi

  local -r cmd="${1:-}"
  shift 2>/dev/null || true

  case "$cmd" in
    init)
      cmd_init "$@"
      ;;
    start)
      cmd_start "$@"
      ;;
    send)
      cmd_send "$@"
      ;;
    list)
      cmd_list "$@"
      ;;
    stop)
      cmd_stop "$@"
      ;;
    kill)
      cmd_kill "$@"
      ;;
    kill-all)
      cmd_kill_all "$@"
      ;;
    help|--help|-h)
      usage
      ;;
    version|--version|-v)
      cmd_version
      ;;
    *)
      log_error "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
