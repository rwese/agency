{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/rwese/agency/main/src/agency/schemas/agents.json",
  "title": "Agency Agents Registry",
  "description": "Registry of agents in an Agency project stored at .agency/agents.yaml",
  "type": "object",
  "required": ["agents"],
  "properties": {
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "config"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Agent name"
          },
          "config": {
            "type": "string",
            "pattern": "^agents/",
            "description": "Path to agent config relative to .agency/"
          }
        },
        "additionalProperties": false
      },
      "description": "List of agent definitions"
    }
  },
  "additionalProperties": false
}
