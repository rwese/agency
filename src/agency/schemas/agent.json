{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/rwese/agency/main/src/agency/schemas/agent.json",
  "title": "Agency Agent Configuration",
  "description": "Configuration for an individual Agency agent",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Agent name"
    },
    "personality": {
      "type": ["string", "null"],
      "description": "Agent personality/prompt (supports template injection)"
    }
  },
  "additionalProperties": false
}
