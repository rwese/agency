#!/usr/bin/expect -f
# test_tui_nav.exp - Panel navigation tests for Agency TUI
#
# Tests panel navigation by verifying:
# 1. TUI launches and shows panels
# 2. Arrow keys don't crash the TUI
# 3. Navigation state is maintained

source [file dirname [info script]]/expect_helpers.exp

set test_name "Panel Navigation"
set passed 0
set failed 0

proc pass {msg} {
    global passed
    puts "\[PASS\] $msg"
    incr passed
}

proc fail {msg} {
    global failed
    puts "\[FAIL\] $msg"
    incr failed
}

# Register cleanup for exit
rename cleanup _cleanup_real
proc cleanup {} {
    catch {_cleanup_real}
}
trap {catch cleanup; exit 1} SIGINT
trap {catch cleanup; exit 1} SIGTERM

puts ""
puts "========================================"
puts "  Test: $test_name"
puts "========================================"

# Reset TUI state
reset_tasks
cleanup

# Launch TUI
puts ""
puts "INFO: Launching TUI..."
if {![launch_tui]} {
    puts "[ERROR] Failed to launch TUI"
    exit 1
}

sleep 2

# Test 1: TUI launches with Sessions panel
puts ""
puts "INFO: Test 1: TUI launches with Sessions panel"
if {[wait_for "Sessions" 3]} {
    pass "TUI shows Sessions panel"
} else {
    fail "TUI should show Sessions panel"
}

# Test 2: TUI shows Tasks panel
puts ""
puts "INFO: Test 2: TUI shows Tasks panel"
if {[wait_for "Tasks" 2]} {
    pass "TUI shows Tasks panel"
} else {
    fail "TUI should show Tasks panel"
}

# Test 3: TUI shows Send Message area
puts ""
puts "INFO: Test 3: TUI shows Send Message area"
if {[wait_for "Send Message" 2] || [wait_for "message" 2]} {
    pass "TUI shows Send Message area"
} else {
    fail "TUI should show Send Message area"
}

# Test 4: Press → does not crash TUI
puts ""
puts "INFO: Test 4: Press → does not crash TUI"
send_key "right"
sleep 1

# Just verify TUI is still running
if {[wait_for "Sessions" 2] || [wait_for "Tasks" 2]} {
    pass "→ key does not crash TUI"
} else {
    fail "TUI should still be running after →"
}

# Test 5: Press ← does not crash TUI
puts ""
puts "INFO: Test 5: Press ← does not crash TUI"
send_key "left"
sleep 1

if {[wait_for "Sessions" 2] || [wait_for "Tasks" 2]} {
    pass "← key does not crash TUI"
} else {
    fail "TUI should still be running after ←"
}

# Test 6: Press ↑ does not crash TUI
puts ""
puts "INFO: Test 6: Press ↑ does not crash TUI"
send_key "up"
sleep 1

if {[wait_for "Sessions" 2] || [wait_for "Tasks" 2]} {
    pass "↑ key does not crash TUI"
} else {
    fail "TUI should still be running after ↑"
}

# Test 7: Press ↓ does not crash TUI
puts ""
puts "INFO: Test 7: Press ↓ does not crash TUI"
send_key "down"
sleep 1

if {[wait_for "Sessions" 2] || [wait_for "Tasks" 2]} {
    pass "↓ key does not crash TUI"
} else {
    fail "TUI should still be running after ↓"
}

# Test 8: Press j does not crash TUI
puts ""
puts "INFO: Test 8: Press j does not crash TUI"
send_key "j"
sleep 1

if {[wait_for "Sessions" 2] || [wait_for "Tasks" 2]} {
    pass "j key does not crash TUI"
} else {
    fail "TUI should still be running after j"
}

# Test 9: Press k does not crash TUI
puts ""
puts "INFO: Test 9: Press k does not crash TUI"
send_key "k"
sleep 1

if {[wait_for "Sessions" 2] || [wait_for "Tasks" 2]} {
    pass "k key does not crash TUI"
} else {
    fail "TUI should still be running after k"
}

# Test 10: Press Enter does not crash TUI
puts ""
puts "INFO: Test 10: Press Enter does not crash TUI"
send_key "enter"
sleep 1

if {[wait_for "Sessions" 2] || [wait_for "Tasks" 2]} {
    pass "Enter does not crash TUI"
} else {
    fail "TUI should still be running after Enter"
}

# Test 11: Press ? for help does not crash TUI
puts ""
puts "INFO: Test 11: Press ? for help"
send_key "?"
sleep 2

if {[wait_for "Sessions" 2] || [wait_for "Tasks" 2] || [wait_for "Quit" 2]} {
    pass "? key shows help without crashing"
} else {
    fail "Help should display"
}

# Test 12: Press Escape dismisses help
puts ""
puts "INFO: Test 12: Press Escape dismisses help"
send_key "escape"
sleep 1

if {[wait_for "Sessions" 2] || [wait_for "Tasks" 2]} {
    pass "Escape dismisses help"
} else {
    fail "Escape should dismiss help"
}

# Summary
puts ""
puts "========================================"
puts "  Results: $passed passed, $failed failed"
puts "========================================"

cleanup

if {$failed > 0} {
    exit 1
}

puts "PASS: $test_name"
exit 0
