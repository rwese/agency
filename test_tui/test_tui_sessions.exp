#!/usr/bin/expect -f
# test_tui_sessions.exp - Session management tests for Agency TUI
#
# Tests session management by verifying:
# 1. Sessions appear in the UI
# 2. Sessions exist in tmux
# 3. Navigation and selection work

source [file dirname [info script]]/expect_helpers.exp

set test_name "Session Management"
set passed 0
set failed 0

proc pass {msg} {
    global passed
    puts "\[PASS\] $msg"
    incr passed
}

proc fail {msg} {
    global failed
    puts "\[FAIL\] $msg"
    incr failed
}

# Helper: Check if session exists in tmux
proc session_exists {pattern} {
    catch {
        set sessions [exec tmux -L agency list-sessions -F "#S"]
        foreach s $sessions {
            if {[string match "*$pattern*" $s]} {
                return 1
            }
        }
    }
    return 0
}

# Register cleanup for exit
rename cleanup _cleanup_real
proc cleanup {} {
    catch {_cleanup_real}
}
trap {catch cleanup; exit 1} SIGINT
trap {catch cleanup; exit 1} SIGTERM

puts ""
puts "========================================"
puts "  Test: $test_name"
puts "========================================"

# Reset state
reset_tasks
cleanup

# Launch TUI with session
puts ""
puts "INFO: Launching TUI with test session..."
if {![launch_tui_with_session]} {
    puts "[ERROR] Failed to launch TUI"
    exit 1
}

puts "INFO: TUI launched, waiting for initial render..."
sleep 2

# Verify Sessions panel is active
puts ""
puts "INFO: Test 1: Sessions panel is active by default"
if {[wait_for "Sessions" 3] && [wait_for "◀" 1]} {
    pass "Sessions panel is active"
} else {
    fail "Sessions panel should be active by default"
}

# Test 2: Session is visible in the list
puts ""
puts "INFO: Test 2: Session is visible in list"
# Should show the example session we created
if {[wait_for "example" 3]} {
    pass "Session visible in list"
} else {
    fail "Session should be visible in list"
}

# Test 3: Session has an agent visible
puts ""
puts "INFO: Test 3: Session agents are visible"
if {[wait_for "example" 2]} {
    pass "Agent visible in session"
} else {
    fail "Agent should be visible in session"
}

# Test 4: Navigate down to session
puts ""
puts "INFO: Test 4: Navigate down with ↓"
send_key "down"
sleep 1

set output [get_pane_content]
# Should show selection indicator ▌
if {[regexp {▌.*example} $output]} {
    pass "↓ navigates to session with selection indicator"
} else {
    fail "↓ should navigate to session with selection indicator"
}

# Test 5: Press Enter to expand agents
puts ""
puts "INFO: Test 5: Enter expands session"
send_key "Enter"
sleep 1

set output [get_pane_content]
# After expand, agents should show with └
if {[regexp {└.*example} $output]} {
    pass "Enter expands session to show agents"
} else {
    fail "Enter should expand session to show agents"
}

# Test 6: Navigate to agent
puts ""
puts "INFO: Test 6: Navigate to agent with ↓"
send_key "down"
sleep 1

set output [get_pane_content]
# Should show agent selection
if {[regexp {└.*example} $output]} {
    pass "↓ navigates to agent"
} else {
    fail "↓ should navigate to agent"
}

# Test 7: Verify tmux session exists
puts ""
puts "INFO: Test 7: Verify session in tmux"
if {[session_exists "agency"]} {
    pass "Session exists in tmux"
} else {
    fail "Session should exist in tmux"
}

# Test 8: Navigate back up
puts ""
puts "INFO: Test 8: Navigate up with ↑"
send_key "Up"
sleep 1

set output [get_pane_content]
# Should go back to session level
if {[regexp {▌.*example} $output]} {
    pass "↑ navigates back to session"
} else {
    fail "↑ should navigate back to session"
}

# Test 9: Session icon visible (🤖)
puts ""
puts "INFO: Test 9: Session has icon"
set output [get_pane_content]
# Look for the emoji icon
if {[regexp {🤖} $output] || [regexp {ð[^\s]} $output]} {
    pass "Session icon visible"
} else {
    fail "Session should have an icon"
}

# Test 10: Attach action (check activity log)
puts ""
puts "INFO: Test 10: Attach action triggers"
send_key "a"
sleep 2

set log [get_activity_log]
if {[string match "*Attach*" $log] || [string match "*attach*" $log]} {
    pass "Attach action logged"
} else {
    fail "Attach action should be logged"
}

# Summary
puts ""
puts "========================================"
puts "  Results: $passed passed, $failed failed"
puts "========================================"

cleanup

if {$failed > 0} {
    exit 1
}

puts "PASS: $test_name"
exit 0
