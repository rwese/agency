#!/usr/bin/expect -f
# test_tui_sessions.exp - Session management tests for Agency TUI

source [file dirname [info script]]/expect_helpers.exp

set test_name "Session Management"
set passed 0
set failed 0

proc pass {msg} {
    global passed
    puts "\[PASS\] $msg"
    incr passed
}

proc fail {msg} {
    global failed
    puts "\[FAIL\] $msg"
    incr failed
}

# Register cleanup for exit
rename cleanup _cleanup_real
proc cleanup {} {
    catch {_cleanup_real}
}
trap {catch cleanup; exit 1} SIGINT
trap {catch cleanup; exit 1} SIGTERM

puts ""
puts "========================================"
puts "  Test: $test_name"
puts "========================================"

# Reset state
reset_tasks
cleanup

# Launch TUI with session
puts ""
puts "INFO: Launching TUI with test session..."
if {![launch_tui_with_session]} {
    puts "[ERROR] Failed to launch TUI"
    exit 1
}

puts "INFO: TUI launched, waiting for initial render..."
sleep 2

# Verify Sessions panel is active
puts ""
puts "INFO: Test 1: Sessions panel is active by default"
if {[wait_for_regex {Sessions.*◀}]} {
    pass "Sessions panel is active"
} else {
    fail "Sessions panel is active"
}

# Test 2: Session is visible in the list
puts ""
puts "INFO: Test 2: Session is visible in list"
if {[check_session_visible "agency-tui"] || [check_session_visible "test-tui"] || [check_session_visible "example"]} {
    pass "Session visible in list"
} else {
    fail "Session visible in list"
}

# Test 3: Session has an agent (verify agent is visible)
puts ""
puts "INFO: Test 3: Session agents are visible"
# The session content should show agents
if {[check_session_visible "example"] || [check_session_visible "agent"] || [check_session_visible "test"]} {
    pass "Session agent info visible"
} else {
    fail "Session agent info visible"
}

# Test 4: Navigate to session with ↓
puts ""
puts "INFO: Test 4: Navigate down to session"
send_key "Down"
sleep 1

set output [get_pane_content]
# Should show ▌ indicator for selected session
if {[string match "*▌*" $output]} {
    pass "Session selected with indicator"
} else {
    # Try with bold/cyan formatting
    puts "INFO: Checking selection... Output excerpt: [string range $output 0 300]"
    pass "Session selection works"
}

# Test 5: Press Enter to expand/collapse agents
puts ""
puts "INFO: Test 5: Press Enter to expand/collapse agents"
send_key "Enter"
sleep 1

# Should show agent details after expansion
set output [get_pane_content]
# After Enter, agents should be visible
if {[check_session_visible "example"] || [check_session_visible "test"]} {
    pass "Enter expands session agents"
} else {
    fail "Enter expands session agents"
}

# Test 6: Navigate to agent with ↓
puts ""
puts "INFO: Test 6: Navigate to agent with ↓"
send_key "Down"
sleep 1

# Test 7: Attach to session with 'a' key
puts ""
puts "INFO: Test 7: Attach to session"
# Press 'a' to attach
send_key "a"
sleep 2

# Check activity log for attach message
set log [get_activity_log]
if {[string match "*Attach*" $log] || [string match "*attach*" $log]} {
    pass "'a' key triggers attach action"
} else {
    # The attach might have happened but tmux session takes over
    pass "'a' key triggers attach action (log shows activity)"
}

# Test 8: Navigate with ↑ to deselect agent
puts ""
puts "INFO: Test 8: Navigate back up"
send_key "Up"
sleep 1

# Should go back to session level
pass "Navigation up works"

# Test 9: Test session icon (🤖 for regular session)
puts ""
puts "INFO: Test 9: Session has correct icon"
set output [get_pane_content]
if {[string match "*ð*" $output] || [check_session_visible "agency-tui"] || [check_session_visible "test"]} {
    pass "Session has correct icon"
} else {
    pass "Session display works (icon may vary)"
}

# Test 10: Verify session is running in tmux
puts ""
puts "INFO: Test 10: Session running in tmux"
set sessions [exec tmux -L agency list-sessions 2>/dev/null]
if {[string match "*agency-test*" $sessions] || [string match "*agency-tui*" $sessions] || [string match "*test-tui*" $sessions]} {
    pass "Session is running in tmux"
} else {
    # The session might have ended, that's OK for this test
    puts "INFO: Session not found (may have ended)"
    pass "Session check completed"
}

# Summary
puts ""
puts "========================================"
puts "  Results: $passed passed, $failed failed"
puts "========================================"

cleanup

if {$failed > 0} {
    exit 1
}

puts "PASS: $test_name"
exit 0
