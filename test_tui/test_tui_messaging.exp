#!/usr/bin/expect -f
# test_tui_messaging.exp - Messaging tests for Agency TUI
#
# Tests messaging functionality by verifying:
# 1. Navigation to message input
# 2. Message input and sending
# 3. Messages persisted to messages.json

source [file dirname [info script]]/expect_helpers.exp

set test_name "Messaging"
set passed 0
set failed 0

proc pass {msg} {
    global passed
    puts "\[PASS\] $msg"
    incr passed
}

proc fail {msg} {
    global failed
    puts "\[FAIL\] $msg"
    incr failed
}

# Helper: Get messages file path
proc get_messages_file {} {
    return [file join $::env(HOME) ".config" "agency" "messages.json"]
}

# Helper: Read messages from file
proc read_messages_file {} {
    set file [get_messages_file]
    if {![file exists $file]} {
        return ""
    }
    if {[catch {exec cat $file} content]} {
        return ""
    }
    return $content
}

# Register cleanup for exit
rename cleanup _cleanup_real
proc cleanup {} {
    catch {_cleanup_real}
}
trap {catch cleanup; exit 1} SIGINT
trap {catch cleanup; exit 1} SIGTERM

puts ""
puts "========================================"
puts "  Test: $test_name"
puts "========================================"

# Reset state
reset_tasks
cleanup

# Launch TUI with session
puts ""
puts "INFO: Launching TUI with test session..."
if {![launch_tui_with_session]} {
    puts "[ERROR] Failed to launch TUI"
    exit 1
}

puts "INFO: TUI launched, waiting for initial render..."
sleep 2

# Navigate to Sessions panel first and select session
puts ""
puts "INFO: Selecting a session..."
send_key "down"  ;# Select session
sleep 1
send_key "Enter"  ;# Expand
sleep 1

# Navigate to Send Message panel
puts ""
puts "INFO: Test 1: Navigate to Send Message panel"
send_key "Right"
sleep 0.5
send_key "Right"
sleep 1

# Verify we're at the message panel
set output [get_pane_content]
if {[regexp {Send Message} $output] || [regexp {message-input} $output] || [regexp {To:} $output]} {
    pass "Navigated to Send Message panel"
} else {
    fail "Should be at Send Message panel"
}

# Test 2: Focus input with 's' key
puts ""
puts "INFO: Test 2: Focus input with 's' key"
send_key "s"
sleep 1

# Verify input area is visible
set output [get_pane_content]
if {[regexp {message-input} $output] || [regexp {Type.*message} $output] || [regexp {To:} $output]} {
    pass "'s' focuses message input area"
} else {
    fail "'s' should focus message input area"
}

# Test 3: Type a message
puts ""
puts "INFO: Test 3: Type a message"
send_text "Test message"
sleep 1

# The typed text should appear in the activity log after sending
# We'll verify this after sending

# Test 4: Send message with Enter
puts ""
puts "INFO: Test 4: Send message with Enter"
press_enter
sleep 3

# Check activity log for sent message
set log [get_activity_log]
if {[regexp {Test message} $log] || [regexp {→} $log] || [regexp {Sent} $log]} {
    pass "Message sent and appears in activity log"
} else {
    fail "Sent message should appear in activity log"
}

# Verify messages.json was created and has the message
set messages_content [read_messages_file]
if {$messages_content ne ""} {
    pass "Message persisted to messages.json"
} else {
    fail "Message should be persisted to messages.json"
}

# Test 5: Input cleared after sending
puts ""
puts "INFO: Test 5: Input cleared after sending"
set output [get_pane_content]
# After sending, the input should be cleared
# We can't easily verify the input field, but we can verify
# the log shows only one message
if {[regexp -all {Test message} $log] == 1} {
    pass "Input appears cleared (single message in log)"
} else {
    fail "Input should be cleared after sending"
}

# Test 6: Target display shows selected session
puts ""
puts "INFO: Test 6: Target display shows selected session"
# Navigate back to sessions
send_key "Left"
sleep 0.5
send_key "Left"
sleep 1

# Select the session
send_key "down"
sleep 1

# Navigate back to message panel
send_key "Right"
sleep 0.5
send_key "Right"
sleep 1

set output [get_pane_content]
# Target display should show session
if {[regexp {To:.*example} $output] || [regexp {To:.*agency} $output] || [regexp {To:.*-} $output]} {
    pass "Target display shows selected session"
} else {
    fail "Target display should show selected session"
}

# Test 7: Send second message
puts ""
puts "INFO: Test 7: Send second message"
send_key "s"
sleep 1
send_text "Second test message"
sleep 1
press_enter
sleep 3

set log [get_activity_log]
if {[regexp {Second test message} $log]} {
    pass "Second message sent"
} else {
    fail "Second message should be sent"
}

# Verify two messages in file
set messages_content [read_messages_file]
if {[regexp -all "\"content\"" $messages_content] >= 2} {
    pass "Multiple messages persisted to file"
} else {
    fail "Multiple messages should be persisted"
}

# Test 8: Empty message handling
puts ""
puts "INFO: Test 8: Empty message not sent"
send_key "s"
sleep 1
# Don't type anything, just press Enter
press_enter
sleep 2

# Count messages before
set msg_count_before [regexp -all \"content\" [read_messages_file]]

# Count messages after
set msg_count_after [regexp -all \"content\" [read_messages_file]]

if {$msg_count_after == $msg_count_before} {
    pass "Empty message not persisted"
} else {
    fail "Empty message should not be persisted"
}

# Summary
puts ""
puts "========================================"
puts "  Results: $passed passed, $failed failed"
puts "========================================"

cleanup

if {$failed > 0} {
    exit 1
}

puts "PASS: $test_name"
exit 0
