#!/usr/bin/expect -f
# test_tui_tasks.exp - Task management tests for Agency TUI
#
# Tests task CRUD operations by verifying:
# 1. Tasks appear in the UI
# 2. Tasks are persisted to tasks.json
# 3. Status changes are reflected in both UI and file

source [file dirname [info script]]/expect_helpers.exp

set test_name "Task Management"
set passed 0
set failed 0

proc pass {msg} {
    global passed
    puts "\[PASS\] $msg"
    incr passed
}

proc fail {msg} {
    global failed
    puts "\[FAIL\] $msg"
    incr failed
}

# Helper: Get tasks file path
proc get_tasks_file {} {
    return [file join $::env(HOME) ".config" "agency" "sessions" "tasks.json"]
}

# Helper: Read tasks from file
proc read_tasks_file {} {
    set tasks_file [get_tasks_file]
    if {![file exists $tasks_file]} {
        return ""
    }
    if {[catch {exec cat $tasks_file} content]} {
        return ""
    }
    return $content
}

# Helper: Count tasks in UI
proc count_tasks_in_ui {} {
    set output [get_pane_content]
    set count 0
    while {[regexp -indices "TASK" $output match]} {
        incr count
        set idx [lindex $match 1]
        incr idx
        set output [string range $output $idx end]
    }
    return $count
}

# Register cleanup for exit
rename cleanup _cleanup_real
proc cleanup {} {
    catch {_cleanup_real}
}
trap {catch cleanup; exit 1} SIGINT
trap {catch cleanup; exit 1} SIGTERM

puts ""
puts "========================================"
puts "  Test: $test_name"
puts "========================================"

# Reset state
reset_tasks
cleanup

# Launch TUI with session
puts ""
puts "INFO: Launching TUI with test session..."
if {![launch_tui_with_session]} {
    puts "[ERROR] Failed to launch TUI"
    exit 1
}

puts "INFO: TUI launched, waiting for initial render..."
sleep 2

# Navigate to Tasks panel first
puts ""
puts "INFO: Navigating to Tasks panel..."
send_key "Right"  ;# Sessions -> Tasks
sleep 1

# Test 1: No tasks initially
puts ""
puts "INFO: Test 1: No tasks initially"
if {[wait_for "No tasks" 3]} {
    pass "No tasks message shown when empty"
} else {
    fail "No tasks message shown when empty"
}

# Verify tasks file doesn't exist
set tasks_content [read_tasks_file]
if {$tasks_content eq ""} {
    pass "Tasks file does not exist initially"
} else {
    fail "Tasks file should not exist initially"
}

# Test 2: Create a task with 'c'
puts ""
puts "INFO: Test 2: Create a task with 'c' key"
send_key "c"
sleep 2

# Check UI shows task
set task_count [count_tasks_in_ui]
if {$task_count >= 1} {
    pass "Task visible in UI after 'c' key"
} else {
    fail "Task should be visible in UI after 'c' key"
}

# Check tasks.json was created and has the task
set tasks_content [read_tasks_file]
if {$tasks_content ne "" && [regexp "TASK" $tasks_content]} {
    pass "Task persisted to tasks.json"
} else {
    fail "Task should be persisted to tasks.json"
}

# Test 3: Task has pending status by default
puts ""
puts "INFO: Test 3: Task has pending status (⏳)"
set output [get_pane_content]
if {[string match "*⏳*" $output]} {
    pass "New task has pending status icon (⏳)"
} else {
    fail "New task should have pending status icon (⏳)"
}

# Verify in file
if {[string match "*pending*" $tasks_content]} {
    pass "Task status is pending in tasks.json"
} else {
    fail "Task status should be pending in tasks.json"
}

# Test 4: Create second task
puts ""
puts "INFO: Test 4: Create second task"
send_key "c"
sleep 2

# Count tasks in UI
set task_count [count_tasks_in_ui]
if {$task_count >= 2} {
    pass "Second task visible in UI"
} else {
    fail "Second task should be visible in UI (found $task_count)"
}

# Verify in file
set tasks_content [read_tasks_file]
if {[regexp -all "TASK" $tasks_content] >= 2} {
    pass "Both tasks persisted to tasks.json"
} else {
    fail "Both tasks should be persisted to tasks.json"
}

# Test 5: Navigate with ↑ to first task
puts ""
puts "INFO: Test 5: Navigate to first task with ↑"
send_key "Up"
sleep 1

set output [get_pane_content]
if {[regexp {▌.*TASK} $output]} {
    pass "↑ navigates and shows selection indicator"
} else {
    fail "↑ should navigate and show selection indicator"
}

# Test 6: Update task status with 'u' - cycles to in_progress
puts ""
puts "INFO: Test 6: Update task status to in_progress"
send_key "u"
sleep 2

set output [get_pane_content]
if {[string match "*🔄*" $output]} {
    pass "Task status changed to in_progress (🔄)"
} else {
    fail "Task status should change to in_progress (🔄)"
}

# Verify in file
set tasks_content [read_tasks_file]
if {[string match "*in_progress*" $tasks_content]} {
    pass "Status updated to in_progress in tasks.json"
} else {
    fail "Status should be in_progress in tasks.json"
}

# Test 7: Update again - cycles to completed
puts ""
puts "INFO: Test 7: Update to completed"
send_key "u"
sleep 2

set output [get_pane_content]
if {[string match "*✅*" $output]} {
    pass "Task status changed to completed (✅)"
} else {
    fail "Task status should change to completed (✅)"
}

# Verify in file
set tasks_content [read_tasks_file]
if {[string match "*completed*" $tasks_content]} {
    pass "Status updated to completed in tasks.json"
} else {
    fail "Status should be completed in tasks.json"
}

# Test 8: Update again - cycles to failed
puts ""
puts "INFO: Test 8: Update to failed"
send_key "u"
sleep 2

set output [get_pane_content]
if {[string match "*❌*" $output]} {
    pass "Task status changed to failed (❌)"
} else {
    fail "Task status should change to failed (❌)"
}

# Test 9: Update again - cycles back to pending
puts ""
puts "INFO: Test 9: Update to pending (cycle complete)"
send_key "u"
sleep 2

set output [get_pane_content]
if {[string match "*⏳*" $output]} {
    pass "Task status cycled back to pending (⏳)"
} else {
    fail "Task status should cycle back to pending (⏳)"
}

# Test 10: Delete task with 'd'
puts ""
puts "INFO: Test 10: Delete task with 'd' key"
set initial_count [count_tasks_in_ui]

send_key "d"
sleep 2

set final_count [count_tasks_in_ui]
if {$final_count < $initial_count} {
    pass "Task count decreased after 'd' key"
} else {
    fail "Task count should decrease after 'd' key"
}

# Verify in file
set tasks_content [read_tasks_file]
if {[regexp -all "TASK" $tasks_content] == 1} {
    pass "One task remaining in tasks.json"
} else {
    fail "One task should remain in tasks.json"
}

# Test 11: Delete all remaining tasks
puts ""
puts "INFO: Test 11: Delete all remaining tasks"
set remaining [count_tasks_in_ui]

for {set i 0} {$i <= $remaining} {incr i} {
    send_key "d"
    sleep 1
}

# Verify UI shows no tasks
if {[wait_for "No tasks" 3]} {
    pass "UI shows no tasks after deletion"
} else {
    fail "UI should show 'No tasks' after deletion"
}

# Verify file is deleted or empty
set tasks_file [get_tasks_file]
if {![file exists $tasks_file]} {
    pass "Tasks file deleted"
} else {
    set tasks_content [read_tasks_file]
    if {$tasks_content eq "" || ![regexp "TASK" $tasks_content]} {
        pass "Tasks file is empty"
    } else {
        fail "Tasks file should be empty"
    }
}

# Test 12: Update with no tasks (verify no crash)
puts ""
puts "INFO: Test 12: Update with no tasks - no crash"
send_key "u"
sleep 1

# Should not crash - check UI is still responsive
if {[wait_for "No tasks" 2]} {
    pass "TUI still responsive after 'u' with no tasks"
} else {
    fail "TUI should remain responsive"
}

# Test 13: Delete with no tasks (verify no crash)
puts ""
puts "INFO: Test 13: Delete with no tasks - no crash"
send_key "d"
sleep 1

# Should not crash
if {[wait_for "No tasks" 2]} {
    pass "TUI still responsive after 'd' with no tasks"
} else {
    fail "TUI should remain responsive"
}

# Summary
puts ""
puts "========================================"
puts "  Results: $passed passed, $failed failed"
puts "========================================"

cleanup

if {$failed > 0} {
    exit 1
}

puts "PASS: $test_name"
exit 0
