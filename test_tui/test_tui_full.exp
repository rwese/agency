#!/usr/bin/expect -f
# test_tui_full.exp - Full workflow E2E test for Agency TUI
#
# Tests complete workflow:
# 1. Create session
# 2. Launch TUI
# 3. Create task
# 4. Send message to agent
# 5. Update task status
# 6. Verify persistence
# 7. Cleanup

source [file dirname [info script]]/expect_helpers.exp

set test_name "Full E2E Workflow"
set passed 0
set failed 0

proc pass {msg} {
    global passed
    puts "\[PASS\] $msg"
    incr passed
}

proc fail {msg} {
    global failed
    puts "\[FAIL\] $msg"
    incr failed
}

# Helper: Get tasks file path
proc get_tasks_file {} {
    return [file join $::env(HOME) ".config" "agency" "sessions" "tasks.json"]
}

# Helper: Get messages file path
proc get_messages_file {} {
    return [file join $::env(HOME) ".config" "agency" "messages.json"]
}

# Helper: Check if session exists in tmux
proc session_exists {pattern} {
    catch {
        set sessions [exec tmux -L agency list-sessions -F "#S"]
        foreach s $sessions {
            if {[string match "*$pattern*" $s]} {
                return 1
            }
        }
    }
    return 0
}

# Helper: Count tasks in UI
proc count_tasks_in_ui {} {
    set output [get_pane_content]
    set count 0
    while {[regexp -indices "TASK" $output match]} {
        incr count
        set idx [lindex $match 1]
        incr idx
        set output [string range $output $idx end]
    }
    return $count
}

# Register cleanup for exit
rename cleanup _cleanup_real
proc cleanup {} {
    catch {_cleanup_real}
}
trap {catch cleanup; exit 1} SIGINT
trap {catch cleanup; exit 1} SIGTERM

puts ""
puts "========================================"
puts "  Test: $test_name"
puts "========================================"

# Reset state
reset_tasks
cleanup

# Step 1: Create a session
puts ""
puts "INFO: Step 1: Create test session"
catch {exec_agency "start example --dir /tmp/agency-e2e-test"}
sleep 2

# Verify session created in tmux
if {[session_exists "agency"]} {
    pass "Session created in tmux"
} else {
    fail "Session should be created in tmux"
}

# Step 2: Launch TUI
puts ""
puts "INFO: Step 2: Launch TUI"
if {![launch_tui]} {
    puts "[ERROR] Failed to launch TUI"
    exit 1
}
sleep 3

# Verify TUI is running
if {[wait_for "Sessions" 3]} {
    pass "TUI launched successfully"
} else {
    fail "TUI should launch successfully"
}

# Step 3: Verify session visible in TUI
puts ""
puts "INFO: Step 3: Verify session visible"
if {[wait_for "example" 3]} {
    pass "Session visible in TUI"
} else {
    fail "Session should be visible in TUI"
}

# Step 4: Navigate to Tasks panel
puts ""
puts "INFO: Step 4: Navigate to Tasks panel"
send_key "right"
sleep 1

if {[wait_for "Tasks" 2]} {
    pass "Navigated to Tasks panel"
} else {
    fail "Should navigate to Tasks panel"
}

# Step 5: Create a task
puts ""
puts "INFO: Step 5: Create task"
send_key "c"
sleep 2

set task_count [count_tasks_in_ui]
if {$task_count >= 1} {
    pass "Task created in TUI"
} else {
    fail "Task should be created in TUI"
}

# Verify task in file
set tasks_file [get_tasks_file]
if {[file exists $tasks_file] && [regexp "TASK" [exec cat $tasks_file]]} {
    pass "Task persisted to file"
} else {
    fail "Task should be persisted to file"
}

# Step 6: Navigate to Sessions
puts ""
puts "INFO: Step 6: Navigate to Sessions"
send_key "left"
sleep 1

if {[wait_for "Sessions" 2]} {
    pass "Navigated to Sessions panel"
} else {
    fail "Should navigate to Sessions panel"
}

# Step 7: Select session
puts ""
puts "INFO: Step 7: Select session"
send_key "down"
sleep 1

set output [get_pane_content]
if {[regexp {▌.*example} $output] || [regexp {example} $output]} {
    pass "Session selected"
} else {
    fail "Session should be selected"
}

# Step 8: Send message
puts ""
puts "INFO: Step 8: Send message"
send_key "right"
sleep 0.5
send_key "right"
sleep 1

send_key "s"
sleep 1

send_text "E2E test message"
sleep 1
press_enter
sleep 3

set log [get_activity_log]
if {[regexp {E2E test} $log]} {
    pass "Message sent"
} else {
    fail "Message should be sent"
}

# Verify message in file
set messages_file [get_messages_file]
if {[file exists $messages_file] && [regexp "E2E test" [exec cat $messages_file]]} {
    pass "Message persisted to file"
} else {
    fail "Message should be persisted to file"
}

# Step 9: Update task status
puts ""
puts "INFO: Step 9: Update task status"
send_key "left"
sleep 0.5
send_key "left"
sleep 1

send_key "down"
sleep 1
send_key "up"
sleep 1

send_key "u"
sleep 2

set output [get_pane_content]
if {[string match "*🔄*" $output] || [string match "*in_progress*" $output]} {
    pass "Task updated to in_progress"
} else {
    fail "Task should be updated to in_progress"
}

# Step 10: Verify session still exists
puts ""
puts "INFO: Step 10: Verify session still exists"
if {[session_exists "agency"]} {
    pass "Session still running in tmux"
} else {
    fail "Session should still be running in tmux"
}

# Summary
puts ""
puts "========================================"
puts "  Results: $passed passed, $failed failed"
puts "========================================"

cleanup

if {$failed > 0} {
    exit 1
}

puts "PASS: $test_name"
exit 0
