    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@hono/node-server": "^1.8.0",
    "@prisma/client": "^5.10.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.0",
    "hono": "^4.0.0",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "prisma": "^5.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "wrangler": "^3.0.0"
